      }
    },
    "tiers": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/AddonTier"
      }
    }
  },
  "required": [
    "addon_id",
    "allowed_quantities",
    "tiers",
    "type"
  ]
}