{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChangeEmail",
  "description": "ChangeEmail schema from Docupilot accounts API",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 255
    },
    "password": {
      "type": "string",
      "maxLength": 128
    }
  },
  "required": [
    "email",
    "password"
  ]
}