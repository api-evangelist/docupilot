{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CSMDetails",
  "description": "CSMDetails schema from Docupilot accounts API",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "maxLength": 100
    },
    "phone_number": {
      "type": "string",
      "maxLength": 20
    }
  },
  "required": [
