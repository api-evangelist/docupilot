{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HistoryRecord",
  "description": "",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "readOnly": true
    },
    "event_name": {
      "enum": [
        "created",
        "invited",
        "send_failed",
        "resent",
        "viewed",
        "signed",
        "completed",
        "declined",
        "voided",
        "recipient_changed"
      ],
      "type": "string"
    },
    "event_meta": {
      "type": "object",
      "additionalProperties": {},
      "nullable": true
    },
    "server_time": {
      "type": "string",
      "format": "date-time"
    },
    "client_time": {
      "type": "string",
      "format": "date-time"
    },
    "ip_address": {
      "type": "string",
      "nullable": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true,
      "description": "Timestamp when this history log was created"
    },
    "actor": {
      "type": "string",
      "readOnly": true
    }
  },
  "required": [
    "actor",
    "client_time",
    "created_at",
    "event_name",
    "id",
    "server_time"
  ]
}