{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TemplateGallery",
  "description": "",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "readOnly": true
    },
    "image_path": {
      "type": "string",
      "readOnly": true
    },
    "file_type": {
      "type": "string",
      "readOnly": true
    },
    "category": {
      "$ref": "#/components/schemas/GalleryCategory"
    },
    "title": {
      "type": "string",
      "maxLength": 50
    },
    "description": {
      "type": "string",
      "nullable": true,
      "maxLength": 255
    },
    "images_count": {
      "type": "integer",
      "maximum": 32767,
      "minimum": 0,
      "nullable": true
    }
  },
  "required": [
    "category",
    "file_type",
    "id",
    "image_path",
    "title"
  ]
}