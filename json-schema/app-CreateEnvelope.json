{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CreateEnvelope",
  "description": "",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "maxLength": 255
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "binary"
      },
      "writeOnly": true,
      "maxItems": 3
    },
    "folder": {
      "type": "integer",
      "nullable": true
    }
  },
  "required": [
    "attachments",
    "name"
  ]
}