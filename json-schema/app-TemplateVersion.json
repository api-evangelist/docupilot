{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TemplateVersion",
  "description": "",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "readOnly": true
    },
    "name": {
      "type": "string",
      "nullable": true,
      "maxLength": 255
    },
    "version_type": {
      "enum": [
        "major",
        "minor",
        null
      ],
      "type": "string",
      "nullable": true
    },
    "starred": {
      "type": "boolean"
    },
    "live": {
      "type": "boolean"
    },
    "created_time": {
      "type": "string",
      "format": "date-time",
      "readOnly": true
    },
    "created_by_user_name": {
      "type": "string",
      "readOnly": true
    }
  },
  "required": [
    "created_by_user_name",
    "created_time",
    "id"
  ]
}