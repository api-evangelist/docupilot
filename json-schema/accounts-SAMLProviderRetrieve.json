    },
    "acs_url": {
      "type": "string",
      "format": "uri",
      "readOnly": true
    },
    "metadata_url": {
      "type": "string",
      "format": "uri",
      "readOnly": true
    },
    "type": {
      "type": "string",
      "readOnly": true
    },
