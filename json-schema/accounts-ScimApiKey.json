{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScimApiKey",
  "description": "ScimApiKey schema from Docupilot accounts API",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "readOnly": true
    },
    "is_active": {
      "type": "boolean",
      "readOnly": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true
    },
    "last_used_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true,
      "nullable": true
    }
  },
  "required": [
    "created_at",
    "id",
    "is_active",
    "last_used_at"
  ]
}