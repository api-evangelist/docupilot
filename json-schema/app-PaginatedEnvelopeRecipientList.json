{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PaginatedEnvelopeRecipientList",
  "description": "PaginatedEnvelopeRecipientList schema from Docupilot app API",
  "type": "object",
  "required": [
    "count",
    "results"
  ],
  "properties": {
    "count": {
      "type": "integer",
      "example": 123
    },
    "next": {
      "type": "string",
      "nullable": true,
      "format": "uri",
      "example": "http://api.example.org/accounts/?page=4"
    },
    "previous": {
      "type": "string",
      "nullable": true,
      "format": "uri",
      "example": "http://api.example.org/accounts/?page=2"
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/EnvelopeRecipient"
      }
    }
  }
}