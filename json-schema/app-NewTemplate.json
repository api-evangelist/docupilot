{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NewTemplate",
  "description": "",
  "type": "object",
  "properties": {
    "file": {
      "type": "string",
      "format": "binary"
    },
    "folder": {
      "type": "integer",
      "nullable": true
    },
    "title": {
      "type": "string",
      "maxLength": 255
    },
    "output_type": {
      "enum": [
        "html",
        "pdf",
        "jpeg",
        "png",
        "docx",
        "pptx",
        "xlsx"
      ],
      "type": "string"
    },
    "description": {
      "type": "string",
      "nullable": true,
      "maxLength": 255
    },
    "template_gallery_id": {
      "type": "integer"
    }
  },
  "required": [
    "output_type",
    "title"
  ]
}