{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workspace",
  "description": "Workspace schema from Docupilot accounts API",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "role": {
      "enum": [
        "owner",
        "admin",
        "manager",
        "member",
        "billing_manager"
      ],
      "type": "string"
    },
    "unique_key": {
      "type": "string"
    },
    "plan": {
      "type": "string"
    },
    "users": {
      "type": "integer"
    },
    "plan_status": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "name",
    "plan",
    "plan_status",
    "unique_key",
    "users"
  ]
}