{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuthToken",
  "description": "",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "readOnly": true
    },
    "token": {
      "type": "string",
      "readOnly": true
    },
    "name": {
      "type": "string",
      "maxLength": 255
    },
    "created_time": {
      "type": "string",
      "format": "date-time",
      "readOnly": true,
      "nullable": true
    },
    "last_used_time": {
      "type": "string",
      "format": "date-time",
      "readOnly": true,
      "nullable": true
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "created_time",
    "id",
    "last_used_time",
    "name",
    "token"
  ]
}