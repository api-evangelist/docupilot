{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChangePassword",
  "description": "ChangePassword schema from Docupilot accounts API",
  "type": "object",
  "properties": {
    "current_password": {
      "type": "string",
      "writeOnly": true
    },
    "new_password": {
      "type": "string",
      "writeOnly": true
    },
    "clear_other_sessions": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "current_password",
    "new_password"
  ]
}