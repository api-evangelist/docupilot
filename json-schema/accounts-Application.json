{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Application",
  "description": "Application schema from Docupilot accounts API",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "readOnly": true
    },
    "name": {
      "type": "string",
      "maxLength": 255
    },
    "hosted_url": {
      "type": "string",
      "readOnly": true
    }
  },
  "required": [
    "hosted_url",
    "id"
  ]
}